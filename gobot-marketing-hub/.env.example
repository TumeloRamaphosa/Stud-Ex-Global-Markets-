# GoBot Marketing Content Hub — Environment Variables
# IMPORTANT: Never commit this file with real values. Copy to .env.local

# Blotato API (multi-platform posting)
BLOTATO_API_KEY=your_blotato_api_key_here
NEXT_PUBLIC_BLOTATO_BASE_URL=https://backend.blotato.com/v2

# Airtable (content calendar & tracking)
AIRTABLE_PAT=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
NEXT_PUBLIC_AIRTABLE_BASE_URL=https://api.airtable.com/v0

# n8n (workflow automation)
N8N_BASE_URL=https://your-n8n-instance.com
N8N_API_KEY=your_n8n_api_key_here
N8N_USERNAME=your_n8n_username
N8N_PASSWORD=your_n8n_password

# Google Calendar (content schedule sync)
GOOGLE_CALENDAR_ID=primary
GOOGLE_ACCESS_TOKEN=your_google_oauth2_access_token_here

# Google Drive (content storage)
GOOGLE_DRIVE_FOLDER_ID=1yD9nwyGqRcHbMOEyoug4kcez5CRBuDLn

# App Config
NEXT_PUBLIC_APP_NAME=GoBot Marketing Hub
NEXT_PUBLIC_APP_URL=http://localhost:3001
